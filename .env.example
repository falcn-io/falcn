# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  FALCN — Environment Variable Reference                                 ║
# ║  Copy this file to .env and fill in all REQUIRED values before starting ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Security (REQUIRED in production) ─────────────────────────────────────────

# Set to 'false' in production — never leave auth disabled on a public instance.
# When empty credentials are configured the server automatically enters dev mode
# (all requests allowed). Set API_AUTH_ENABLED=true to prevent this.
API_AUTH_ENABLED=true

# Comma-separated API keys (min 32 chars each). At least one is required when
# API_AUTH_ENABLED=true and JWT is not used.
# Generate: openssl rand -hex 32
API_KEYS=CHANGE_ME_API_KEY_AT_LEAST_32_CHARS_LONG

# Path to RSA private key file for JWT signing (RS256).
# Generate: openssl genrsa -out /run/secrets/falcn_jwt.key 4096
FALCN_JWT_PRIVATE_KEY_FILE=/run/secrets/falcn_jwt.key

# Alternatively, provide the PEM-encoded key inline (use \n for line breaks).
# FALCN_JWT_PRIVATE_KEY=

# 32-byte AES key for encrypting sensitive data at rest.
# Generate: openssl rand -hex 16
FALCN_SECURITY_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_AES_KEY_HEX

# ── CORS (REQUIRED in production) ─────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# In production the server will exit on startup if this is not set.
# Example: https://security.mycompany.com,https://falcn.mycompany.com
FALCN_CORS_ORIGINS=https://your-falcn-domain.example.com

# ── Application ───────────────────────────────────────────────────────────────

# Set to 'production' to enable stricter checks (CORS enforcement, no dev mode).
FALCN_APP_ENVIRONMENT=production

# Server listen port (default: 8080)
PORT=8080

# Log level: debug | info | warn | error
FALCN_LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────

# Database backend: 'sqlite' (single node) or 'postgres' (HA / multi-replica)
FALCN_DB_TYPE=sqlite

# SQLite: path to the database file (used when FALCN_DB_TYPE=sqlite)
FALCN_DB_NAME=/app/data/falcn.db

# PostgreSQL (used when FALCN_DB_TYPE=postgres)
# FALCN_DB_HOST=postgres
# FALCN_DB_PORT=5432
# FALCN_DB_NAME=falcn
# FALCN_DB_USER=falcn
# FALCN_DB_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD
# FALCN_DB_SSLMODE=require   # Always use 'require' or 'verify-full' in production

# ── TLS (recommended in production) ───────────────────────────────────────────

# Paths to TLS certificate and private key (enables HTTPS on the API port).
# If not set, the server listens on plain HTTP — use a TLS-terminating reverse
# proxy (nginx, Caddy, AWS ALB) in front of the API service instead.
# FALCN_TLS_CERT=/run/secrets/falcn_tls.crt
# FALCN_TLS_KEY=/run/secrets/falcn_tls.key

# ── AI / LLM Explanations (optional) ──────────────────────────────────────────

# OpenAI API key for threat explanations
# FALCN_OPENAI_API_KEY=sk-...

# Anthropic API key
# FALCN_ANTHROPIC_API_KEY=sk-ant-...

# Ollama host (for local/air-gapped deployments)
# FALCN_OLLAMA_HOST=http://localhost:11434

# ── Integrations (optional) ───────────────────────────────────────────────────

# Slack webhook for high-risk alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Microsoft Teams webhook
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ── Metrics / Observability (optional) ────────────────────────────────────────

# Prometheus metrics scrape: /metrics endpoint.
# Restrict access to your internal monitoring network via a reverse proxy or
# firewall — the endpoint itself has no authentication.
# Example: allow your Prometheus server IP only.

# Redis URL for distributed rate limiting (falls back to in-memory if unset)
# RATE_LIMIT_REDIS_URL=redis://redis:6379

# ── Monitoring (Grafana, optional) ────────────────────────────────────────────

# Grafana admin password (used only by docker-compose monitoring profile)
# Generate: openssl rand -base64 24
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
